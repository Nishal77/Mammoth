# ============================================================
# MAMMOTH — Environment Variables
# Copy to .env.local and fill in values.
# Never commit .env.local to version control.
# ============================================================

# === DATABASE ===
DATABASE_URL=postgresql://mammoth:mammoth_dev_pass@localhost:5432/mammoth_dev
REDIS_URL=redis://:redis_dev_pass@localhost:6379/0

# === AUTHENTICATION (Better Auth) ===
BETTER_AUTH_SECRET=change-me-to-a-32-char-secret-in-production
BETTER_AUTH_URL=http://localhost:3000

# === AI MODELS ===
ANTHROPIC_API_KEY=sk-ant-           # Claude SDK — required
OPENAI_API_KEY=sk-                  # Embeddings (text-embedding-3-small) — required
PERPLEXITY_API_KEY=pplx-            # Research agent web search — optional

# === VECTOR DB ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                     # Empty for local dev, required for Qdrant Cloud

# === FILE STORAGE (MinIO / S3-compatible) ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=mammoth
S3_REGION=us-east-1

# === ENCRYPTION ===
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change-me-base64-encoded-32-byte-key
KMS_KEY_ID=                         # AWS KMS key ARN — production only

# === NOTIFICATIONS ===
# Founders receive approvals, briefings, and Ring 2 veto alerts via Telegram or WhatsApp.
# Approval actions (approve/veto/modify) happen directly inside the chat via bot buttons.
RESEND_API_KEY=re_                  # Transactional email (account events only)
TELEGRAM_BOT_TOKEN=                 # Telegram bot — primary notification channel
TELEGRAM_BOT_USERNAME=              # Without @, e.g. mammoth_dev_bot
TELEGRAM_WEBHOOK_DOMAIN=            # Public HTTPS domain for bot webhook (production only)
META_WHATSAPP_TOKEN=                # WhatsApp Business Cloud API — secondary channel
META_WHATSAPP_PHONE_ID=             # WhatsApp sender phone ID
META_WHATSAPP_VERIFY_TOKEN=         # Arbitrary secret for Meta webhook verification
NOTIFICATION_SERVICE_PORT=3002      # Port for notification service Fastify server

# === OBSERVABILITY ===
SENTRY_DSN=                         # Sentry project DSN
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=mammoth-api

# === BILLING ===
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_GROWTH_PRICE_ID=price_
STRIPE_SCALE_PRICE_ID=price_

# === WEB APP ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# === FEATURE FLAGS ===
ENABLE_CLOUD_BILLING=false
ENABLE_ENTERPRISE_SSO=false
MAX_AGENT_COST_PER_DAY_USD=50

# ============================================================
# MAMMOTH — Environment Variables
# Copy to .env.local and fill in values.
# Never commit .env.local to version control.
# ============================================================

# === DATABASE ===
DATABASE_URL=postgresql://mammoth:mammoth_dev_pass@localhost:5432/mammoth_dev
REDIS_URL=redis://:redis_dev_pass@localhost:6379/0

# === AUTHENTICATION (Better Auth) ===
BETTER_AUTH_SECRET=change-me-to-a-32-char-secret-in-production
BETTER_AUTH_URL=http://localhost:3000

# === AI MODELS ===
ANTHROPIC_API_KEY=sk-ant-           # Claude SDK — required
OPENAI_API_KEY=sk-                  # Embeddings (text-embedding-3-small) — required
PERPLEXITY_API_KEY=pplx-            # Research agent web search — deprecated, use EXA_API_KEY

# === VECTOR DB ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                     # Empty for local dev, required for Qdrant Cloud

# === FILE STORAGE (MinIO / S3-compatible) ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=mammoth
S3_REGION=us-east-1

# === ENCRYPTION ===
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change-me-base64-encoded-32-byte-key
KMS_KEY_ID=                         # AWS KMS key ARN — production only

# === NOTIFICATIONS ===
# Founders receive approvals, briefings, and Ring 2 veto alerts via Telegram or WhatsApp.
# Approval actions (approve/veto/modify) happen directly inside the chat via bot buttons.
RESEND_API_KEY=re_                  # Transactional email (account events only)
TELEGRAM_BOT_TOKEN=                 # Telegram bot — primary notification channel
TELEGRAM_BOT_USERNAME=              # Without @, e.g. mammoth_dev_bot
TELEGRAM_WEBHOOK_DOMAIN=            # Public HTTPS domain for bot webhook (production only)
META_WHATSAPP_TOKEN=                # WhatsApp Business Cloud API — secondary channel
META_WHATSAPP_PHONE_ID=             # WhatsApp sender phone ID
META_WHATSAPP_VERIFY_TOKEN=         # Arbitrary secret for Meta webhook verification
NOTIFICATION_SERVICE_PORT=3002      # Port for notification service Fastify server

# === OBSERVABILITY ===
SENTRY_DSN=                         # Sentry project DSN
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=mammoth-api

# === BILLING ===
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_GROWTH_PRICE_ID=price_
STRIPE_SCALE_PRICE_ID=price_

# === WEB APP ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# === REAL-TIME SEARCH (Exa AI) ===
# Research agent and Marketing agent use Exa for live web search.
# Without this, agents fall back to model knowledge (no live data).
EXA_API_KEY=                        # Get from exa.ai — grounded live search

# === LEAD ENRICHMENT (Apollo.io) ===
# Sales agent uses Apollo for real prospect data instead of AI-synthesised leads.
APOLLO_API_KEY=                     # Get from apollo.io — real B2B lead database

# === SOCIAL MEDIA POSTING ===
# LinkedIn and Twitter credentials are stored per-company in the integrations table,
# encrypted with per-company keys. These are fallback dev defaults only.
LINKEDIN_CLIENT_ID=                 # LinkedIn OAuth app client ID
LINKEDIN_CLIENT_SECRET=             # LinkedIn OAuth app client secret
TWITTER_CLIENT_ID=                  # Twitter OAuth 2.0 client ID
TWITTER_CLIENT_SECRET=              # Twitter OAuth 2.0 client secret

# === AI VOICE CALLING (Vapi) ===
# Support agent uses Vapi for AI-powered outbound callbacks.
VAPI_API_KEY=                       # Get from vapi.ai
VAPI_PHONE_NUMBER_ID=               # Vapi phone number to call from

# === GITHUB WEBHOOKS ===
# Engineering agent auto-triggers PR reviews when a PR is opened.
GITHUB_WEBHOOK_SECRET=              # Arbitrary secret set in GitHub repo webhook settings

# === ENVOY PROXY ===
ENVOY_ADMIN_PORT=9901
ENVOY_PUBLIC_PORT=8080
ENVOY_INTERNAL_PORT=8081

# === EMAIL FROM ADDRESS ===
EMAIL_FROM=MAMMOTH <noreply@mammoth.dev>

# === FEATURE FLAGS ===
ENABLE_CLOUD_BILLING=false
ENABLE_ENTERPRISE_SSO=false
MAX_AGENT_COST_PER_DAY_USD=50
ENABLE_BROWSER_WORKER=false         # Set true to start browser automation tasks
ENABLE_VOICE_CALLING=false          # Set true to allow Vapi outbound calls

# === N8N AUTOMATION BRIDGE ===
# MAMMOTH fires a webhook to this URL after each approved action executes.
# Connect to N8N workflow: set provider="n8n" integration with metadata.webhookUrl
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/mammoth-actions

# === HASHICORP VAULT (optional) ===
# If set, secrets are fetched from Vault instead of environment variables.
# Leave unset in development — reads from env vars automatically.
VAULT_ADDR=                         # e.g. https://vault.company.internal:8200
VAULT_TOKEN=                        # Service token with read access to secret/data/mammoth/*
VAULT_MOUNT=secret                  # KV v2 mount path (default: secret)

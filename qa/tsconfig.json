{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "tests/**/*.ts",
    "fixtures/**/*.ts",
    "helpers/**/*.ts",
    "data/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "playwright-report"]
}

{
  "name": "@mammoth/memory-database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "main": "./src/index.ts",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5",
    "zod": "^3.24.1",
    "ioredis": "^5.4.2",
    "@mammoth/shared": "workspace:*"
  },
  "devDependencies": {
    "@mammoth/typescript-config": "workspace:*",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
